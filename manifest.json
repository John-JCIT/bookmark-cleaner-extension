{
  "manifest_version": 3,
  "name": "Bookmark Cleaner",
  "version": "1.0",
  "description": "Manage and clean up your Chrome bookmarks with a proper UI. Browse folders, rename, delete, and scan your entire library for dead links.",
  "homepage_url": "https://www.fairdinkum.dev",
  "permissions": ["bookmarks", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Bookmark Cleaner",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["index.html", "style.css", "app.js"],
    "matches": ["<all_urls>"]
  }]
}
